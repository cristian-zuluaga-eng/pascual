# Notion Integration Token
# Get it from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your_integration_token_here

# Database IDs
# Find these in the URL when opening each database:
# https://www.notion.so/workspace/DATABASE_ID?v=...

# CONDOR Module - Portfolio & Configuration Database
CONDOR_CONFIG_DB_ID=your_32_char_hex_database_id

# CONDOR Module - Reports Database
CONDOR_REPORTS_DB_ID=your_32_char_hex_database_id

# IDEAS Module - Software Ideas Database
IDEAS_DB_ID=your_32_char_hex_database_id

# SPORTS Module - Sports Betting Database
SPORTS_DB_ID=your_32_char_hex_database_id
